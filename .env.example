# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="the-seed"
APP_ENV=local
APP_DEBUG=true
APP_KEY=

# ── Domain / SSL ───────────────────────────────────────────────────────────────
# Default: HTTP on localhost — works with no setup at all.
# For HTTPS with a custom domain see README § "HTTPS with custom domain".
APP_URL=http://localhost
APP_DOMAIN=seed.local

# ── PHP / Node versions (used as Dockerfile ARGs) ─────────────────────────────
PHP_VERSION=8.3
NODE_VERSION=20

# ── Database ───────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=seeddb
DB_USERNAME=seeduser
DB_PASSWORD=secret

# ── PostgreSQL container ───────────────────────────────────────────────────────
# Keep these in sync with DB_* above
POSTGRES_DB=seeddb
POSTGRES_USER=seeduser
POSTGRES_PASSWORD=secret
POSTGRES_VERSION=16

# ── Sessions ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_STORE=database

# ── Queue ──────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── Mail (dev: Mailpit catches everything, no real email sent) ─────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@seed.local
MAIL_FROM_NAME="the-seed"

# ── Gmail override (production) ────────────────────────────────────────────────
# Uncomment and fill in to send real email via Gmail.
# Requires a Gmail App Password (not your account password).
# Generate at: https://myaccount.google.com/apppasswords
#
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM_ADDRESS=you@gmail.com

# ── Demo credentials (seeded on first `just up`) ───────────────────────────────
DEMO_USER_EMAIL=admin@seed.local
DEMO_USER_PASSWORD=password

# ── Ports ──────────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
POSTGRES_PORT=5432
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025
ADMINER_PORT=8081
