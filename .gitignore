# Secrets — never commit
.env
configs/msmtprc

# SSL certificates — generated locally by mkcert
docker/certs/*.pem

# Laravel auto-generated infrastructure — created at first run by entrypoint.sh.
# Only our custom files are tracked (controllers, models, routes, views, seeders).
seed-laravel/vendor/
seed-laravel/node_modules/
seed-laravel/.env
seed-laravel/composer.json
seed-laravel/composer.lock
seed-laravel/artisan
seed-laravel/package.json
seed-laravel/package-lock.json
seed-laravel/vite.config.js
seed-laravel/phpunit.xml
seed-laravel/.editorconfig
seed-laravel/.env.example
seed-laravel/.gitattributes
seed-laravel/.gitignore
seed-laravel/.npmrc
seed-laravel/README.md
seed-laravel/config/
seed-laravel/app/Http/Controllers/Controller.php
seed-laravel/app/Providers/
seed-laravel/database/factories/
seed-laravel/database/migrations/
seed-laravel/database/.gitignore
seed-laravel/public/.htaccess
seed-laravel/public/favicon.ico
seed-laravel/public/index.php
seed-laravel/public/robots.txt
seed-laravel/public/build/
seed-laravel/resources/css/
seed-laravel/resources/js/
seed-laravel/routes/console.php
seed-laravel/storage/
seed-laravel/tests/
seed-laravel/bootstrap/cache/
seed-laravel/bootstrap/providers.php

# NestJS — node_modules are installed at container startup, not committed
seed-nest/node_modules/
seed-nest/dist/

# Logs — all log dirs are bind-mounted to logs/ and readable offline
# Ignore everything inside each dir; .gitkeep files keep the dirs in git.
logs/nginx/*
logs/php/*
logs/app/*
logs/postgres/*
logs/mail/*
logs/python/*
logs/nest/*

# PostgreSQL data volume
database/data/

# Docker local overrides
docker-compose.override.yml

# Claude Code
.claude/settings.local.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo
