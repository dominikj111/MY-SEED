# Secrets — never commit
.env
configs/msmtprc

# SSL certificates — generated locally by mkcert
docker/certs/*.pem

# Laravel auto-generated infrastructure — created at first run by entrypoint.sh.
# Only our custom files are tracked (controllers, models, routes, views, seeders).
app/vendor/
app/node_modules/
app/.env
app/composer.json
app/composer.lock
app/artisan
app/package.json
app/package-lock.json
app/vite.config.js
app/phpunit.xml
app/.editorconfig
app/.env.example
app/.gitattributes
app/.gitignore
app/.npmrc
app/README.md
app/config/
app/app/Http/Controllers/Controller.php
app/app/Providers/
app/database/factories/
app/database/migrations/
app/database/.gitignore
app/public/.htaccess
app/public/favicon.ico
app/public/index.php
app/public/robots.txt
app/public/build/
app/resources/css/
app/resources/js/
app/routes/console.php
app/storage/
app/tests/
app/bootstrap/cache/
app/bootstrap/providers.php

# Logs — all log dirs are bind-mounted to logs/ and readable offline
# Ignore everything inside each dir; .gitkeep files keep the dirs in git.
logs/nginx/*
logs/php/*
logs/app/*
logs/postgres/*
logs/mail/*

# PostgreSQL data volume
database/data/

# Docker local overrides
docker-compose.override.yml

# Claude Code
.claude/settings.local.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo
