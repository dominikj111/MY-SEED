<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>body{background:#f8f9fa}</style>
</head>
<body>
{{> navbar}}
<main class="container py-5">
  <h2 class="mb-4">Dashboard</h2>

  <div class="row g-3 mb-4">
    <div class="col-sm-4">
      <div class="card text-center shadow-sm border-danger">
        <div class="card-body">
          <div class="display-6 fw-bold text-danger">{{userCount}}</div>
          <div class="text-muted small">Users in DB</div>
        </div>
      </div>
    </div>
    <div class="col-sm-4">
      <div class="card text-center shadow-sm border-success">
        <div class="card-body">
          <div class="display-6 fw-bold text-success">{{tokenCount}}</div>
          <div class="text-muted small">API Tokens</div>
        </div>
      </div>
    </div>
    <div class="col-sm-4">
      <div class="card text-center shadow-sm border-info">
        <div class="card-body">
          <div class="display-6 fw-bold text-info" style="font-size:1.1rem">{{user.email}}</div>
          <div class="text-muted small">Logged in as</div>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Your API Tokens</div>
    <div class="card-body">
      {{#if myTokens.length}}
        <table class="table table-sm mb-0">
          <thead><tr><th>Name</th><th>Token (truncated)</th><th>Created</th></tr></thead>
          <tbody>
            {{#each myTokens}}
            <tr>
              <td>{{name}}</td>
              <td><code>{{preview}}</code></td>
              <td>{{createdAt}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      {{else}}
        <p class="text-muted mb-0">No tokens yet. Issue one via the API.</p>
      {{/if}}
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-header fw-semibold">Quick API test</div>
    <div class="card-body">
      <pre><code># Issue a token
curl -s -X POST http://localhost/nest/api/v1/auth/token \
  -H 'Content-Type: application/json' \
  -d '{"email":"{{user.email}}","password":"password"}' | python3 -m json.tool

# Use it
curl -H 'Authorization: Bearer &lt;token&gt;' http://localhost/nest/api/v1/me</code></pre>
    </div>
  </div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
