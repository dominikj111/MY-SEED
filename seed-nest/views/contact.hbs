<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>body{background:#f8f9fa}</style>
</head>
<body>
{{> navbar}}
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-7">
      <h2 class="mb-4">Contact</h2>

      {{#if sent}}
        <div class="alert alert-success">
          Message sent! Check <a href="http://localhost:8025" target="_blank">Mailpit</a> to see it.
        </div>
      {{/if}}

      <div class="card shadow-sm">
        <div class="card-body p-4">
          <form method="post" action="/nest/contact">
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input name="name" type="text" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input name="email" type="email" class="form-control" required>
            </div>
            <div class="mb-4">
              <label class="form-label">Message</label>
              <textarea name="message" class="form-control" rows="5" required minlength="10"></textarea>
            </div>
            <button type="submit" class="btn btn-danger">Send Message</button>
            <a href="/nest/dashboard" class="btn btn-link">Back to Dashboard</a>
          </form>
        </div>
      </div>
    </div>
  </div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
