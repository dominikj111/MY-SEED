<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>body{background:#f8f9fa}</style>
</head>
<body>
{{> navbar}}
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 text-center">
      <h1 class="display-5 fw-bold mb-3">the-seed <span class="badge" style="background:#e0234e">NestJS</span></h1>
      <p class="lead text-muted mb-4">NestJS · TypeORM · PostgreSQL · Mailpit · Docker</p>

      <div class="row g-3 mb-5">
        <div class="col-sm-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title">Session Auth</h5>
              <p class="card-text text-muted small">Passport local strategy — email login, express-session, guarded routes.</p>
              <a href="/nest/login" class="btn btn-danger btn-sm">Login</a>
            </div>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title">REST API</h5>
              <p class="card-text text-muted small">Public endpoints and Bearer-token protected routes with Swagger docs.</p>
              <a href="/nest/api/v1/status" class="btn btn-outline-secondary btn-sm" target="_blank">Public API</a>
            </div>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title">Contact Form</h5>
              <p class="card-text text-muted small">Sends mail via Nodemailer → Mailpit. Login required.</p>
              <a href="/nest/contact" class="btn btn-outline-danger btn-sm">Contact</a>
            </div>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title">API Docs</h5>
              <p class="card-text text-muted small">Auto-generated Swagger UI via @nestjs/swagger.</p>
              <a href="/nest/api/v1/docs" class="btn btn-outline-secondary btn-sm" target="_blank">Swagger</a>
            </div>
          </div>
        </div>
      </div>

      <div class="card text-start shadow-sm">
        <div class="card-header fw-semibold">Quick API reference</div>
        <div class="card-body">
          <pre><code># Public
curl http://localhost/nest/api/v1/status
curl http://localhost/nest/api/v1/ping

# Issue a token
curl -s -X POST http://localhost/nest/api/v1/auth/token \
  -H 'Content-Type: application/json' \
  -d '{"email":"admin@seed.local","password":"password"}' | python3 -m json.tool

# Private (replace TOKEN)
curl -H 'Authorization: Bearer TOKEN' http://localhost/nest/api/v1/me</code></pre>
        </div>
      </div>
    </div>
  </div>
</main>
<footer class="text-center text-muted py-3 border-top">
  <small>the-seed · NestJS stack — TypeORM · PostgreSQL · Mailpit</small>
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
