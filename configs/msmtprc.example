# msmtp configuration — copy to configs/msmtprc and fill in credentials.
# configs/msmtprc is gitignored (never commit credentials).
#
# How msmtp integrates with PHP:
#   php.ini sendmail_path = /usr/bin/msmtp -t
#   Laravel Mail facade uses Laravel's SMTP mailer (configured via .env MAIL_*)
#   PHP's built-in mail() function uses this msmtprc config
#
# To switch to Gmail for production:
#   1. Fill in the [google] account below
#   2. Change the last line: account default : google
#   3. Restart the php container: docker compose restart php

defaults
auth           off
tls            off
logfile        /var/log/mail/msmtp.log

# ── Local development: Mailpit catches all mail ───────────────────────────────
# Mailpit web UI: http://localhost:8025
# No authentication required — accepts everything
account mailpit
host    mailpit
port    1025

# ── Production: Gmail via App Password ────────────────────────────────────────
# Requirements:
#   - Gmail account with 2-Step Verification enabled
#   - App Password generated at: https://myaccount.google.com/apppasswords
#   - Use the App Password here, NOT your Gmail login password
account google
host             smtp.gmail.com
port             587
from             you@gmail.com
user             you@gmail.com
password         YOUR_16_CHAR_APP_PASSWORD
auth             on
tls              on
tls_starttls     on
tls_trust_file   /etc/ssl/certs/ca-certificates.crt

# ── Default account used by PHP mail() ───────────────────────────────────────
account default : mailpit
